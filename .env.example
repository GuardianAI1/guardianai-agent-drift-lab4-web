# Backend service URLs (for local dev).
# In production, app routes fall back to https://guardianai.fr/core and https://guardianai.fr/gate if unset.
GUARDIAN_CORE_URL=http://127.0.0.1:18101
GUARDIAN_GATE_URL=http://127.0.0.1:18102
# Shared gateway key for protected /core and /gate endpoints
GUARDIAN_ENDPOINT_KEY=

# API hardening for local API routes (/api/*)
# Comma-separated browser origin allowlist used by anti-bot guard.
GUARDIAN_API_ALLOWED_ORIGINS=https://app.guardianai.fr,https://guardianai.fr,https://www.guardianai.fr,http://localhost:3000,http://127.0.0.1:3000
# Optional shared key for server-to-server callers to /api/* (header: X-Guardian-Lab-Key or Authorization: Bearer).
GUARDIAN_WEB_API_KEY=
# Optional per-route rate limits (requests per minute).
GUARDIAN_RATE_LIMIT_LLM_RPM=30
GUARDIAN_RATE_LIMIT_OBSERVE_RPM=240
GUARDIAN_RATE_LIMIT_CONSTRAINT_RPM=120
GUARDIAN_RATE_LIMIT_REPORT_RPM=30

# Optional server-side default API keys (leave empty if users provide keys in UI)
TOGETHER_API_KEY=
OPENAI_API_KEY=
# Optional OpenAI routing context (set only if your key requires explicit org/project headers)
OPENAI_ORGANIZATION=
OPENAI_PROJECT=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
MISTRAL_API_KEY=

# Optional landing page website link shown in the app
NEXT_PUBLIC_GUARDIAN_WEBSITE_URL=https://guardianai.fr
# Optional UI signal visibility mode: public (default, black-box) or private (full diagnostics)
NEXT_PUBLIC_SIGNAL_VISIBILITY=public

# Optional GitHub repository link shown in the app
NEXT_PUBLIC_GITHUB_REPO_URL=
